{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "acara-app/plate",
    "type": "project",
    "description": "Acara Plate - AI-powered personalized nutrition and meal planning platform for diabetes management.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4 || ^8.5",
        "acara-app/acara-core": "dev-main",
        "defstudio/telegraph": "^1.70.5",
        "inertiajs/inertia-laravel": "^3.1.0",
        "laravel/ai": "^0.6.8",
        "laravel/cashier": "^16.5.3",
        "laravel/fortify": "^1.37.2",
        "laravel/framework": "^13.13",
        "laravel/reverb": "^1.10",
        "laravel/sanctum": "^4.3.2",
        "laravel/socialite": "^5.27.0",
        "laravel/tinker": "^3.0.2",
        "laravel/wayfinder": "^0.1.20",
        "league/commonmark": "^2.8.2",
        "league/flysystem-aws-s3-v3": "^3.34.0",
        "livewire/livewire": "^4.3.1",
        "nunomaduro/essentials": "^1.2.0",
        "ryangjchandler/laravel-cloudflare-turnstile": "^3.0.3",
        "spatie/laravel-data": "^4.23.0",
        "spatie/laravel-mailcoach-mailer": "^1.6.0",
        "spatie/laravel-sitemap": "^7.4.0"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7.0",
        "driftingly/rector-laravel": "dev-main",
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.10.0",
        "laravel/boost": "^2.4.8",
        "laravel/pail": "^1.2.7",
        "laravel/pint": "^1.29.1",
        "mockery/mockery": "^1.6.12",
        "laravel/pao": "^1.1.0",
        "nunomaduro/collision": "^8.9.4",
        "pestphp/pest": "^4.7.2",
        "pestphp/pest-plugin-browser": "^4.3.1",
        "pestphp/pest-plugin-laravel": "^4.1.0",
        "pestphp/pest-plugin-type-coverage": "^4.0.4",
        "rector/rector": "^2.4.5",
        "roave/security-advisories": "dev-latest",
        "spatie/boost-spatie-guidelines": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "bun install",
            "bun run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "bunx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74,#a3e635\" \"php artisan serve\" \"php artisan queue:work redis --queue=chat,default --tries=3\" \"php artisan pail --timeout=0\" \"bun run dev\" \"php artisan reverb:start\" --names=server,queue,logs,vite,reverb --kill-others"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan optimize:clear --ansi",
            "@update:requirements",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "update:requirements": [
            "composer bump",
            "bunx npm-check-updates -u"
        ],
        "lint": [
            "rector",
            "pint --parallel",
            "bun run lint"
        ],
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:lint": [
            "pint --parallel --test",
            "rector --dry-run",
            "bun run test:lint"
        ],
        "test:unit": "pest --parallel --coverage --exactly=100.0",
        "test:types": [
            "phpstan",
            "bun run test:types"
        ],
        "test": [
            "@test:type-coverage",
            "@test:unit",
            "@test:lint",
            "@test:types"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": {
        "acara-core": {
            "type": "vcs",
            "url": "https://github.com/acara-app/acara-core.git"
        }
    }
}
